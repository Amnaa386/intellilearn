# Database
DATABASE_URL=sqlite:///./ai_tutor.db

# JWT
JWT_SECRET=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API Keys (add your actual keys)
# IMPORTANT: Replace these with your actual API keys
GROQ_API_KEY=gsk_your_actual_groq_key_here
GEMINI_API_KEY=your_actual_gemini_key_here
DEEPSEEK_API_KEY=your_actual_deepseek_key_here
OPENAI_API_KEY=your_actual_deepseek_key_here

# For testing without API keys, you can use mock responses
# Set USE_MOCK_AI=true to enable mock responses for testing
USE_MOCK_AI=true

# Development Mode
DEV_MODE=true
BYPASS_AUTH=true
MOCK_USER_ID=1
MOCK_USER_EMAIL=dev@test.com
MOCK_USER_USERNAME=dev_user
LOG_BYPASS=true
