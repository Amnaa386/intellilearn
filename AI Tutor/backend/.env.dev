# Development Environment Configuration
# Set these environment variables to enable development mode

# Enable development mode
DEV_MODE=true

# Bypass authentication for testing
BYPASS_AUTH=true

# Mock user data for development
MOCK_USER_ID=1
MOCK_USER_EMAIL=dev@test.com
MOCK_USER_USERNAME=dev_user

# Log authentication bypass attempts
LOG_BYPASS=true

# AI API Keys (use your actual keys)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Database (can use SQLite for development)
DATABASE_URL=sqlite:///./ai_tutor_dev.db

# JWT Settings
JWT_SECRET=dev_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
